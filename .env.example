# Public marketing site URL.
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3000

# Product app URL. Kept for demo/future app links; login/register CTAs currently use newsletter signup.
NEXT_PUBLIC_APP_URL=http://127.0.0.1:8000

# Newsletter/waitlist form.
# Recommendation for MVP: Brevo Free plan. Paste the hosted form POST action from your Brevo form embed.
# Do not put private API keys in NEXT_PUBLIC_* variables.
NEXT_PUBLIC_NEWSLETTER_PROVIDER=Brevo
NEXT_PUBLIC_NEWSLETTER_FORM_ACTION=https://YOUR_BREVO_FORM_ACTION_URL
NEXT_PUBLIC_NEWSLETTER_FORM_METHOD=post
NEXT_PUBLIC_NEWSLETTER_EMAIL_FIELD=EMAIL

# Optional hidden metadata fields. Leave names blank if your provider does not support them.
NEXT_PUBLIC_NEWSLETTER_SOURCE_FIELD=
NEXT_PUBLIC_NEWSLETTER_SOURCE_VALUE=next-site
NEXT_PUBLIC_NEWSLETTER_TAG_FIELD=
NEXT_PUBLIC_NEWSLETTER_TAG_VALUE=launch-newsletter
